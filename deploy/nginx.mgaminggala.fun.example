# Nginx for https://mgaminggala.fun — proxy ALL traffic to THIS app's port only.
# Replace CIV_PORT with the dedicated port for mgaminggala_MTN_CIV (see .env PORT).
# Do NOT point this domain at another project's port.

server {
    listen 80;
    server_name mgaminggala.fun www.mgaminggala.fun;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name mgaminggala.fun www.mgaminggala.fun;

    # ssl_certificate     /path/to/fullchain.pem;
    # ssl_certificate_key /path/to/privkey.pem;

    location / {
        proxy_pass http://127.0.0.1:CIV_PORT;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}

# Test on domain:
#   curl "https://mgaminggala.fun/api/civmtn/login?pid=3&msisdn=225YOUR_NUMBER"
